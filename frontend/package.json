{
  "name": "frontend",
  "private": true,
  "version": "2.1.1",
  "type": "module",
  "scripts": {
    "gen:openapi": "cross-env NARRATIVE_OPENAPI_OUT=../../openapi.json node scripts/run-export-openapi.mjs",
    "gen:types": "pnpm run gen:openapi && pnpm exec openapi-typescript ../../openapi.json -o src/types/api.gen.ts && node scripts/postprocess-openapi-types.mjs",
    "dev": "pnpm run gen:types && vite",
    "build": "pnpm run gen:types && vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@types/d3": "^7.4.3",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "axios": "^1.14.0",
    "d3": "^7.9.0",
    "d3-force": "^3.0.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "cross-env": "^7.0.3",
    "jsdom": "^29.0.2",
    "msw": "^2.13.2",
    "openapi-typescript": "^7.8.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.5"
  }
}
