          "notes": "魔道之首，门下弟子修炼血魔功法，以杀戮取乐，正道之敌，仙界所共讨之。"
        },
        {
          "id": "bb05d7ac-6d18-4a7f-85cd-5ee8ce4f2e95",
          "name": "铁血盟",
          "scope": "internal",
          "description": "凡界最大的武修联盟，成员均为身经百战的武修强者，誓死守护凡界边境。盘踞铁血关，作为对抗域外势力的第一道防线。",
          "territory_region_ids": [
            "e8474404-c984-4882-84be-a04350a6ab05"
          ],
          "alignment": "lawful_neutral",
          "relation_map": {},
          "power_system_id": null,
          "notes": "凡界护卫者，铁律治军，誓死不退，与域外魔族有血海深仇，与正道保持中立盟约。"
        },
        {
          "id": "8d80a81c-bb58-492e-ab9b-59a3c77be497",
          "name": "赤炎阁",
          "scope": "internal",
          "description": "凡界最顶尖的炼丹势力，专精火系灵物炼制与火法器铸造。盘踞赤炎荒漠，垄断凡界高阶丹药市场，财力雄厚。",
          "territory_region_ids": [
            "e8474404-c984-4882-84be-a04350a6ab05"
          ],
          "alignment": "neutral_good",
          "relation_map": {},
          "power_system_id": null,
          "notes": "炼丹界泰斗，中立不参与正邪纷争，但倾向于供应正道，以丹药之道回馈修仙界。"
        },
        {
          "id": "c87bd696-9063-4ac4-a07b-538e18bdde14",
          "name": "星海阁",
          "scope": "internal",
          "description": "以星海湖为据点的水修门派，擅长水系功法与占卜之术，是凡界最神秘的势力之一。门下高手众多，善于预测命运走向。",
          "territory_region_ids": [
            "e8474404-c984-4882-84be-a04350a6ab05"
          ],
          "alignment": "neutral_good",
          "relation_map": {},
          "power_system_id": null,
          "notes": "神秘的水修门派，以预测闻名于世，很少主动介入正邪争斗，但关键时刻往往扮演决定性角色。"
        },
        {
          "id": "f5b7290d-720f-49cb-99e3-6d3b49d9f887",
          "name": "太虚仙朝",
          "scope": "internal",
          "description": "统治仙界数万年的最高权力机构，以太虚仙宫为中心。汇聚整个仙界最强大的真仙，制定并维护仙界秩序与法则。",
          "territory_region_ids": [
            "e8474404-c984-4882-84be-a04350a6ab05"
          ],
          "alignment": "lawful_good",
          "relation_map": {},
          "power_system_id": null,
          "notes": "仙界最高权威，号令诸仙，维护天道平衡，曾多次镇压域外势力入侵与魔道叛乱。"
        },
        {
          "id": "83e8f8d7-656c-4d86-9336-d4bc73c08a65",
          "name": "神道圣院",
          "scope": "internal",
          "description": "神道体系的核心机构，以神殿山为圣地，汇聚所有神官与信仰修士。拥有神圣的神力与赐福能力，守护苍生。",
          "territory_region_ids": [
            "e8474404-c984-4882-84be-a04350a6ab05"
          ],
          "alignment": "lawful_good",
          "relation_map": {},
          "power_system_id": null,
          "notes": "神道修士的精神家园，以神力信仰为核心，与太虚仙朝既有合作又有理念分歧，强调信仰而非权力。"
        },
        {
          "id": "48feaf34-a707-4075-a775-803cd148737d",
          "name": "域外魔族",
          "scope": "external",
          "description": "来自九天玄界之外的魔族势力，意图入侵并吞噬整个世界的灵气。长期在混沌边境觊觎，是所有仙界势力的共同敌人。",
          "territory_region_ids": [
            "e8474404-c984-4882-84be-a04350a6ab05"
          ],
          "alignment": "chaotic_evil",
          "relation_map": {},
          "power_system_id": null,
          "notes": "外来入侵者，破坏九天玄界秩序，铁血盟在凡界层层阻拦，太虚仙朝在仙界部署防线。"
        }
