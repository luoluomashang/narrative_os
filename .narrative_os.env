# ============================================================
# Narrative OS — 配置文件示例
# 将此文件重命名为 .narrative_os.env 并按需修改
# 不要将含真实密钥的文件提交到版本控制
# ============================================================

# --------------------------------------------------
# LLM 后端密钥（至少配置一个）
# --------------------------------------------------

# OpenAI：支持 GPT-4o、GPT-4-turbo 等
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic：支持 Claude 3.5 Sonnet、Claude 3 Haiku 等
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama（本地部署，无需 API Key）
# 启动方式：ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# DeepSeek：高性价比中文模型（deepseek-chat / deepseek-reasoner）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-e7c0f11db63542eb871dad7cf882e388

# --------------------------------------------------
# 自定义 OpenAI 兼容端点
# 适用于：vLLM 自部署、LM Studio、Azure OpenAI、本地 llama.cpp 等任意兼容 OpenAI API 的服务
# --------------------------------------------------
CUSTOM_LLM_BASE_URL=http://localhost:8080/v1
CUSTOM_LLM_API_KEY=
# 各精度层对应的模型名（填写你的服务中实际部署的模型名）
CUSTOM_LLM_MODEL_SMALL=custom-small
CUSTOM_LLM_MODEL_MEDIUM=custom-medium
CUSTOM_LLM_MODEL_LARGE=custom-large

# --------------------------------------------------
# LLM 路由策略
# 可选：QUALITY_FIRST / COST_OPTIMIZED / SPEED_FIRST
# --------------------------------------------------
LLM_STRATEGY=COST_OPTIMIZED

# 各策略首选模型（留空则使用内置默认值）
QUALITY_MODEL=gpt-4o
COST_MODEL=claude-3-haiku-20240307
SPEED_MODEL=llama3

# --------------------------------------------------
# Token 预算控制
# --------------------------------------------------

# 每日 Token 总配额（默认 100,000）
DAILY_TOKEN_BUDGET=100000

# 单章 Token 上限（默认 20,000）
PER_CHAPTER_BUDGET=20000

# 超预算时行为：warn（警告但继续）/ block（阻止生成）
BUDGET_EXCEEDED_ACTION=warn

# --------------------------------------------------
# 向量数据库（ChromaDB）
# --------------------------------------------------

# 数据库本地存储路径（相对于工作目录）
CHROMA_DB_PATH=.narrative_db

# --------------------------------------------------
# 状态持久化
# --------------------------------------------------

# 项目状态文件目录
STATE_DIR=.narrative_state

# --------------------------------------------------
# 日志
# --------------------------------------------------

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志文件目录（留空则只输出到控制台）
LOG_DIR=.narrative_os/logs

# --------------------------------------------------
# 开发服务器
# --------------------------------------------------

# 后端 API 监听地址
DEV_HOST=127.0.0.1

# 后端 API 端口（默认 8000）
DEV_API_PORT=8000

# 前端 Vite 开发服务器端口（默认 5173）
DEV_FRONTEND_PORT=5173

# --------------------------------------------------
# TRPG 互动模式
# --------------------------------------------------

# 会话超时时间（秒，默认 3600）
SESSION_TTL=3600

# TRPG 单会话最大回合数（默认 30）
MAX_HISTORY_TURNS=30

# 默认叙事密度：dense / normal / sparse
DEFAULT_DENSITY=normal

# --------------------------------------------------
# 质量审查阈值
# --------------------------------------------------

# 章节通过所需最低质量分（0.0–1.0）
QUALITY_THRESHOLD=0.65

# 章节通过所需最低钩子分
HOOK_THRESHOLD=0.5

# 审查不通过时最多重写次数
MAX_RETRIES=3
